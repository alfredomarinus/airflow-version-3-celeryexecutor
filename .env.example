# Container Runtime Configuration
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow
TZ=Asia/Kuala_Lumpur

# Airflow Admin User (created during deployment)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
_AIRFLOW_WWW_USER_EMAIL=admin@example.com
_AIRFLOW_WWW_USER_FIRSTNAME=Admin
_AIRFLOW_WWW_USER_LASTNAME=User
_AIRFLOW_WWW_USER_ROLE=Admin

# Airflow Security Secrets (regenerate for production)
# Generate Fernet Key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME
# Generate API Secret: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(16)).decode())"
AIRFLOW__CORE__INTERNAL_API_SECRET_KEY=CHANGE_ME
AIRFLOW__API__SECRET_KEY=CHANGE_ME
AIRFLOW__API_AUTH__JWT_SECRET=CHANGE_ME

# PostgreSQL (for Airflow metadata)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_HOST=postgres

# Redis (for Celery broker)
REDIS_PASSWORD=redispass

# Additional Python Packages
_PIP_ADDITIONAL_REQUIREMENTS=